def fix_characters(datainfo):
    if not datainfo: return ""
    return datainfo.replace(";", " - ").replace("►", " - ").replace("–", " - ").replace(",", " - ")

# URL base
BASE_URL = "http://sisregiii.saude.gov.br/cgi-bin/config_preparo"
LOGIN_URL = "https://sisregiii.saude.gov.br"

# 1. Iniciar Sessão+++
session = requests.Session()

# 2. Realizar Login

payload = {
    'usuario': 'CR.AMBULATORIOADM',
    'senha_256': '7140d1314b6b310142b290043096b8e549e712d39ab0daa6fb7870b2a55e8901',
    'etapa' : "ACESSO"
}

print("Realizando login...")
response = session.post(LOGIN_URL, data=payload, headers=headers)
if "Efetue o logon novamente" in response.text:
    raise Exception("Erro no login. Verifique as credenciais ou o site.")

print("Acessando lista de unidades...")
res = session.get(BASE_URL)
soup = BeautifulSoup(res.text, 'lxml')

form = soup.find('form')
if form:
    table = form.find('table')
    if table:
        rows = table.find_all('tr')
        if len(rows) > 1:
            unidade_options = rows[1].find_all('option')
        else:
            print("Tabela não tem linhas suficientes.")
            unidade_options = []
    else:
        print("Tabela não encontrada.")
        unidade_options = []
else:
    print("Formulário não encontrado.")
    unidade_options = []

data = []

for index, unidade in enumerate(unidade_options):
    nome_unidade = unidade.text.strip()
    valor_unidade = unidade['value']
    
    if not valor_unidade: continue
    
    print(f"Unidade {index}: {nome_unidade}")

    params_proc = {
        'etapa': 'LISTAR_PROCEDIMENTOS',
        'unidade': valor_unidade
    }
    
    try:
        res_proc = session.get(BASE_URL, params=params_proc)
        soup_proc = BeautifulSoup(res_proc.text, 'lxml')
        procedimentos_unidade = soup_proc.form.table('tr')[2]('option')
    except Exception as e:
        print(f"Erro ao buscar procedimentos da unidade {nome_unidade}: {e}")
        continue

    for index_j, procedimento in enumerate(procedimentos_unidade):
        if index_j < 1: continue

        nome_procedimento = procedimento.text.strip()
        valor_procedimento = procedimento['value']
        
        print(f"\tProcedimento {index_j}: {nome_procedimento}")

        params_prep = {
            'etapa': 'FRM_PREPARO',
            'unidade': valor_unidade,
            'procedimento': valor_procedimento
        }

        try:
            res_prep = session.get(BASE_URL, params=params_prep)
            soup_prep = BeautifulSoup(res_prep.text, 'lxml')
            
            iframe = soup_prep.find('iframe', {'name': 'preparo_ifr'})
            
            if iframe:
                url_iframe = "http://sisregiii.saude.gov.br" + iframe['src']
                res_info = session.get(url_iframe)
                soup_info = BeautifulSoup(res_info.text, 'lxml')
            else:
                soup_info = soup_prep

            descricao_preparo_tags = str(soup_info.body)
            descricao_preparo = soup_info.body.get_text(separator=" ").strip() if soup_info.body else ""

        except Exception as e:
            print(f"Erro no procedimento {nome_procedimento}: {e}")
            descricao_preparo = "ERRO"
            descricao_preparo_tags = ""

        data.append({
            "cnes": valor_unidade,
            "nomeUnidade": nome_unidade,
            "codProcedimento": valor_procedimento,
            "nomeProcedimento": nome_procedimento,
            "descricaoPreparo": fix_characters(descricao_preparo),
            "descricaoPreparoTags": fix_characters(descricao_preparo_tags)
        })
        
        time.sleep(0.5)

# 6. Salvar Dados no BigQuery
print("Registrando dados no BigQuery...")
client = bigquery.Client()
table_id = "seu_projeto.seu_dataset.preparos_unidades"  # ajuste para seu projeto/dataset/tabela

df = pd.DataFrame(data)
job = client.load_table_from_dataframe(df, table_id)
job.result()

print("Processo finalizado com sucesso! Dados inseridos no BigQuery.")
